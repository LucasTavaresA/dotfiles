# sway
xwayland enable
## mouse
mouse_warping container
focus_follows_mouse no
seat seat0 xcursor_theme 'Adwaita' 14
seat seat0 hide_cursor 3000
seat seat0 hide_cursor when-typing enable
## touchpad
input type:touchpad {
    tap enabled
    dwt enabled
    pointer_accel 0.3
}
## janelas
default_orientation vertical
workspace_layout tabbed
title_align center
focus_wrapping no
focus_on_window_activation focus
## teclado
input type:keyboard {
    xkb_layout custom
    xkb_options caps:swapescape
    # xkb_numlock enable
    repeat_delay 300
    repeat_rate 100
}

# Aparência
output * bg $HOME/media/imagens/wallpapers/stsr1.png fill
## sem abas
font pango:monospace 0.001
titlebar_border_thickness 0
titlebar_padding 0
## bordas
smart_borders on
hide_edge_borders smart
for_window [app_id=".*"] border pixel 1
default_border pixel 1
default_floating_border pixel 4
## cores
### classe               borda   fundo   texto   indicador  child_border
client.focused           #d65d0e #ffffff #ffffff #83a598    #83a598
client.focused_inactive  #282828 #282828 #ffffff #282828    #282828
client.unfocused         #282828 #282828 #ffffff #282828    #282828
client.urgent            #ff0000 #282828 #ffffff #ff0000    #ff0000
client.placeholder       #555555 #555555 #ffffff #555555    #555555
client.background        #000000

# Regras
for_window [app_id="^Picture-in-Picture$"] {
  floating enable
  resize set height 350
  resize set width  600
  border none
  sticky toggle
  move position 680 370
  opacity 0.85
}
for_window [title="^Picture-in-Picture$"] {
  floating enable
  resize set height 350
  resize set width  600
  border none
  sticky toggle
  move position 680 370
  opacity 0.85
}
## Não desliga a tela quando em tela cheia
for_window [class="^.*"] inhibit_idle fullscreen
for_window [app_id="^.*"] inhibit_idle fullscreen
for_window [app_id=".*"] title_window_icon on
for_window [app_id="^menu$"] floating enable, border pixel 4, resize set 400 300, move position center
for_window [app_id="^float$"] floating enable, border pixel 4, resize set 1000 600, move position center
for_window [app_id="^calculadora"] floating enable, border pixel 4, resize set 400 400, move position center
for_window [app_id="org.qutebrowser.qutebrowser"] focus
for_window [app_id="^Firefox$"] focus
for_window [app_id="^firefox$"] focus
for_window [app_id="^emacs$"] focus
for_window [instance="^emacs$"] focus
for_window [app_id="^nvim$"] focus
for_window [app_id="^foot$"] focus
for_window [app_id="^alacritty$"] focus
for_window [app_id="^mpv$"] focus
for_window [app_id="^ncmpcpp$"] focus
for_window [app_id="^Gimp$"] focus
for_window [app_id="^discord$"] focus
for_window [app_id="^irc$"] focus
for_window [instance="^hexchat$"] focus
for_window [title="^Easy Effects$"] focus
for_window [title="Inkscape$"] focus
for_window [instance="^irc$"] focus
for_window [app_id="^TelegramDesktop$"] focus
assign [app_id="org.qutebrowser.qutebrowser"] "1:Browser"
assign [app_id="^Firefox$"] "1:Browser"
assign [app_id="^firefox$"] "1:Browser"
assign [app_id="^emacs$"] "2:Code"
assign [instance="^emacs$"] "2:Code"
assign [app_id="^nvim$"] "2:Code"
assign [app_id="^foot$"] "2:Code"
assign [app_id="^alacritty$"] "2:Code"
assign [app_id="^mpv$"] "3:Fullscreen"
assign [title="^Easy Effects$"] "3:Fullscreen"
assign [app_id="^ncmpcpp$"] "3:Fullscreen"
assign [app_id="^Gimp$"] "3:Fullscreen"
assign [title="Inkscape$"] "3:Fullscreen"
assign [app_id="^discord$"] "4:Message"
assign [instance="^hexchat$"] "4:Message"
assign [app_id="^irc$"] "4:Message"
assign [instance="^irc$"] "4:Message"
assign [app_id="^TelegramDesktop$"] "4:Message"

# Teclas
set $A Mod1
set $S Mod4
set $s Shift
floating_modifier $S normal
## sway
bindsym $S+q kill
bindsym $S+w floating toggle
bindsym $S+f fullscreen toggle
bindsym $S+s sticky toggle
bindsym $S+b bar hidden_state toggle
bindsym $S+tab exec swayr next-window current-workspace
bindsym Print exec wayland_print
bindsym $S+p exec wayland_print
bindsym $S+o exec menu_pesquisar
bindsym $S+Return exec term_open
## menu
mode "Menu" {
    bindsym Menu exec tofi-drun --drun-launch=true ; mode "default"
    bindsym o exec orgmenu ~/documentos/favs.md ; mode "default"
    bindsym m exec menu_mont ; mode "default"
    bindsym p exec keepassxc ; mode "default"
    bindsym c exec cliphist list | tofi --padding-left 0 --padding-top 0 | cliphist decode | wl-copy ; mode "default"
    bindsym Shift+c exec term_open -a calculadora python ; mode "default"
    bindsym e exec term_open -a nvim nvim ~/documentos/ ; mode "default"
    bindsym Shift+e exec term_open -a float fzf_emojis ; mode "default"
    bindsym f exec qutebrowser ; mode "default"
    bindsym h exec term_open -a float htop ; mode "default"
    bindsym s exec pgrep -x gammastep && pkill -x gammastep || gammastep -O 3000 ; mode "default"
    bindsym l exec swaylock -c 000000ff --scaling fill ; mode "default"
    bindsym a exec term_open -a nvim nvim ~/documentos/anotações.md ; mode "default"
    bindsym r reload
    bindsym Shift+q exit
    bindsym escape ; mode "default"
}
bindsym Menu mode "Menu"
## resize mode
mode "resize" {
        bindsym h resize shrink width 10 px or 10 ppt
        bindsym j resize grow height 10 px or 10 ppt
        bindsym k resize shrink height 10 px or 10 ppt
        bindsym l resize grow width 10 px or 10 ppt
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $S+r mode "default"
}
bindsym $S+r mode "resize"
## musica
bindsym $S+a exec term_open -a ncmpcpp ncmpcpp
bindsym $S+$s+a exec term_open -a float pulsemixer
bindsym $S+space exec playerctl play-pause || mpc toggle
bindsym XF86AudioPlay exec playerctl play-pause || mpc toggle
bindsym $S+comma exec pactl -- set-sink-volume @DEFAULT_SINK@ -5%
bindsym $S+period exec pactl -- set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec pactl -- set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioRaiseVolume exec pactl -- set-sink-volume @DEFAULT_SINK@ +5%
bindsym $S+$s+comma exec musica ante
bindsym $S+$s+period exec musica prox
## setas/vimkeys
bindsym $S+Up focus up
bindsym $S+Down focus down
bindsym $S+Left focus left
bindsym $S+Right focus right
bindsym $S+$s+Up move up
bindsym $S+$s+Down move down
bindsym $S+$s+Left move left
bindsym $S+$s+Right move right
bindsym $S+k focus up
bindsym $S+j focus down
bindsym $S+h focus left
bindsym $S+l focus right
bindsym $S+$s+k move up
bindsym $S+$s+j move down
bindsym $S+$s+h move left
bindsym $S+$s+l move right
## workspaces
set $ws1 "1:Browser"
set $ws2 "2:Code"
set $ws3 "3:Fullscreen"
set $ws4 "4:Message"
set $ws5 "5:HDMI"
bindsym $S+1 workspace number $ws1
bindsym $S+2 workspace number $ws2
bindsym $S+3 workspace number $ws3
bindsym $S+4 workspace number $ws4
bindsym $S+5 workspace number $ws5
bindsym $S+$s+1 move window to workspace number $ws1
bindsym $S+$s+2 move window to workspace number $ws2
bindsym $S+$s+3 move window to workspace number $ws3
bindsym $S+$s+4 move window to workspace number $ws4
bindsym $S+$s+5 move window to workspace number $ws5

# Iniciar
exec swayrd
exec swayidle -w timeout 500 'swaymsg "output * power off"' resume 'swaymsg "output * power on"'
exec wl-paste --watch cliphist store
exec mako
# exec easyeffects
exec sway-audio-idle-inhibit
## Musica
exec pgrep -x "playerctld" || playerctld daemon
exec pgrep -x "mpDris2" || mpDris2 --music-dir="$HOME/media/musicas/" >"$XDG_CACHE_HOME/mpdris2.log" 2>&1 &
## aparência
exec xrdb -load $HOME/.config/X11/Xresources
## sistema
exec checar_updates
exec notify-bat

## Barra
bar {
  swaybar_command waybar
  mode hide
  hidden_state hide
  modifier Mod4
}
