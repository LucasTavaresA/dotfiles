# sway
xwayland enable
## mouse
mouse_warping container
focus_follows_mouse no
## janelas
floating_minimum_size 500 x 300
floating_maximum_size 1000 x 600
default_orientation vertical
workspace_layout tabbed
title_align center
focus_wrapping no
focus_on_window_activation focus
## teclado
input type:keyboard {
    xkb_layout br
    xkb_options caps:escape_shifted_capslock
    xkb_numlock enable
    repeat_delay 300
    repeat_rate 100
}

# Aparência
## sem abas
font pango:monospace 0
titlebar_border_thickness 0
titlebar_padding 0
## bordas
smart_borders on
hide_edge_borders smart
for_window [app_id=".*"] border pixel 1
default_border pixel 1
default_floating_border pixel 4
## cores
### classe              borda   fundo   texto   indicador  child_border
client.focused          #ffffff #000000 #ffffff #ffffff    #ffffff
client.focused_inactive #000000 #000000 #ffffff #000000    #000000
client.unfocused        #000000 #000000 #ffffff #000000    #000000
client.urgent           #ff0000 #000000 #ffffff #ff0000    #ff0000
client.placeholder      #555555 #555555 #ffffff #555555    #555555
client.background       #ffffff

# Regras
## Não desliga a tela quando em tela cheia
for_window [class="^.*"] inhibit_idle fullscreen
for_window [app_id="^.*"] inhibit_idle fullscreen
for_window [app_id=".*"] title_window_icon on
for_window [app_id="^menu$"] floating enable, border pixel 4, resize set 400 300, move position center
for_window [app_id="^float$"] floating enable, border pixel 4, resize set 1000 600, move position center
for_window [app_id="^pinentry-qt$"] floating enable, border pixel 4, resize set 600 400, move position center
for_window [app_id="^calculadora"] floating enable, border pixel 4, resize set 200 200, move position center
for_window [app_id="org.qutebrowser.qutebrowser"] focus
for_window [app_id="^Firefox$"] focus
for_window [app_id="^firefox$"] focus
for_window [app_id="^emacs$"] focus
for_window [instance="^emacs$"] focus
for_window [app_id="^nvim$"] focus
for_window [app_id="^foot$"] focus
for_window [app_id="^alacritty$"] focus
for_window [app_id="^mpv$"] focus
for_window [app_id="^Gimp$"] focus
for_window [app_id="^discord$"] focus
for_window [app_id="^emacsirc$"] focus
for_window [instance="^emacsirc$"] focus
for_window [app_id="^TelegramDesktop$"] focus
assign [app_id="org.qutebrowser.qutebrowser"] "1:Browser"
assign [app_id="^Firefox$"] "1:Browser"
assign [app_id="^firefox$"] "1:Browser"
assign [app_id="^emacs$"] "2:Code"
assign [instance="^emacs$"] "2:Code"
assign [app_id="^nvim$"] "2:Code"
assign [app_id="^foot$"] "2:Code"
assign [app_id="^alacritty$"] "2:Code"
assign [app_id="^mpv$"] "3:Fullscreen"
assign [app_id="^Gimp$"] "3:Fullscreen"
assign [app_id="^discord$"] "4:Message"
assign [app_id="^emacsirc$"] "4:Message"
assign [instance="^emacsirc$"] "4:Message"
assign [app_id="^TelegramDesktop$"] "4:Message"

# Teclas
set $fuzzelopts "-I --terminal=term_open -x 0 -y 0 -p 0 -b 000000ff -t ffffffff -m ff0000ff -S 000000ff -B 1 -r 0 -C ffffffff --show-actions -f Terminus:size=16 -P '>'"
set $mod Mod4
set $mods Mod4+Shift
floating_modifier $mod normal
## sway
bindsym $mod+q kill
bindsym $mod+w floating toggle, border pixel 4, sticky true
bindsym $mod+f fullscreen toggle
bindsym $mod+b bar hidden_state toggle
bindsym $mod+tab exec sway-overfocus split-rw group-rw float-rw
bindsym Print exec wayland_print
bindsym $mod+e exec emacs
bindsym $mods+Return exec term_open
## menu
mode "Menu" {
    bindsym Menu exec fuzzel "$fuzzelopts" -w 35 ; mode "default"
    bindsym Escape exec powermenu ; mode "default"
    bindsym XF86Launch2 exec powermenu ; mode "default"
    bindsym o exec orgmenu ~/documentos/favoritos.org ; mode "default"
    bindsym m exec menu_mont ; mode "default"
    bindsym p exec keepmenu ; mode "default"
    bindsym c exec clipman pick --tool fuzzel --tool-args=$fuzzelopts ; mode "default"
    bindsym Shift+c exec term_open -a calculadora python ; mode "default"
    bindsym Shift+e exec term_open -a float fzf_emojis ; mode "default"
    bindsym q exec qutebrowser ; mode "default"
    bindsym f exec firefox ; mode "default"
    bindsym h exec term_open -a float htop ; mode "default"
    bindsym s exec gammastep -O 3000 ; mode "default"
    bindsym Shift+s exec pkill -x gammastep ; mode "default"
    bindsym t exec transmission-qt ; mode "default"
    bindsym e exec emacsclient -n -c -a 'term_open nvim' ; mode "default"
    bindsym a exec term_open nvim ~/documentos/anotações.org ; mode "default"
    bindsym i exec term_open nvim ~/documentos/inf.org ; mode "default"
    bindsym l exec swaylock -c 000000ff --scaling fill ; mode "default"
    bindsym r reload
    bindsym Shift+q exit
}
bindsym Menu mode "Menu"
## resize mode
mode "resize" {
        bindsym h resize shrink width 10 px or 10 ppt
        bindsym j resize grow height 10 px or 10 ppt
        bindsym k resize shrink height 10 px or 10 ppt
        bindsym l resize grow width 10 px or 10 ppt
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"
## musica
bindsym $mod+a exec term_open -a float ncmpcpp
bindsym $mods+a exec term_open -a float pulsemixer
bindsym $mod+space exec playerctl play-pause || mpc toggle
bindsym XF86AudioPlay exec playerctl play-pause || mpc toggle
bindsym $mod+comma exec pactl set-sink-volume @DEFAULT_SINK@ -5% && pkill -SIGRTMIN+22 i3blocks
bindsym $mod+period exec pactl set-sink-volume @DEFAULT_SINK@ +5% && pkill -SIGRTMIN+22 i3blocks
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5% && pkill -SIGRTMIN+22 i3blocks
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5% && pkill -SIGRTMIN+22 i3blocks
bindsym $mods+comma exec musica ante && pkill -SIGRTMIN+18 i3blocks
bindsym $mods+period exec musica prox && pkill -SIGRTMIN+18 i3blocks
## setas/vimkeys
bindsym $mod+Up focus up
bindsym $mod+Down focus down
bindsym $mod+Left focus left
bindsym $mod+Right focus right
bindsym $mods+Up move up
bindsym $mods+Down move down
bindsym $mods+Left move left
bindsym $mods+Right move right
bindsym Mod1+Left workspace prev
bindsym Mod1+Right workspace next
bindsym $mod+k focus up
bindsym $mod+j focus down
bindsym $mod+h focus left
bindsym $mod+l focus right
bindsym $mods+k move up
bindsym $mods+j move down
bindsym $mods+h move left
bindsym $mods+l move right
bindsym Mod1+h workspace next
bindsym Mod1+l workspace prev
## workspaces
set $ws1 "1:Browser"
set $ws2 "2:Code"
set $ws3 "3:Fullscreen"
set $ws4 "4:Message"
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mods+1 move window to workspace number $ws1
bindsym $mods+2 move window to workspace number $ws2
bindsym $mods+3 move window to workspace number $ws3
bindsym $mods+4 move window to workspace number $ws4

# Iniciar
exec swayidle -w timeout 500 'swaymsg "output * dpms off"' resume 'swaymsg "output * dpms on"'
exec wl-paste -t text --watch clipman store 1>> $XDG_DATA_HOME/clipman.log 2>&1 &
exec fzf_man update
exec mako
exec syncthing
exec transmission-qt -m
exec emacs --name=emacsirc --title=emacsirc -Q --load '~/.config/emacs/irc.el'
exec emacs --daemon
exec foot -s
## musica
exec pipewire
exec pipewire-pulse
exec wireplumber
exec mpd
exec mpDris2 --music-dir="$HOME/media/musicas/"
exec playerctld daemon
exec mpc update
## aparência
exec swaybg -i $HOME/media/imagens/wallpapers/kaiji_friends.png -m fill
exec xrdb -load $HOME/.config/x11/xresources
## sistema
exec checar_updates

## Barra
bar {
    colors {
        background #000000ff
        statusline #ffffffff
        separator #ffffffff
        focused_workspace #ffffffff #ffffffff #000000ff
        inactive_workspace #000000ff #000000ff #ffffffff
        urgent_workspace #ff0000ff #ff0000ff #000000ff
    }
    font pango:Terminus 12
    status_command i3blocks
    strip_workspace_numbers yes
    position top
    height 16
    mode hide
        hidden_state hide
        modifier Mod4
}
