# sway
xwayland disable
## mouse
mouse_warping container
focus_follows_mouse no
seat seat0 xcursor_theme 'Capitaine Cursors (Gruvbox)' 14
## touchpad
input type:touchpad {
    tap enabled
    dwt enabled
    pointer_accel 0.3
}
## janelas
default_orientation vertical
workspace_layout tabbed
title_align center
focus_wrapping no
focus_on_window_activation focus
## teclado
input type:keyboard {
    xkb_layout custom
    xkb_options caps:swapescape
    xkb_numlock enable
    repeat_delay 300
    repeat_rate 100
}

# Aparência
output * bg $HOME/media/imagens/wallpapers/kaiji_dice.png stretch
## sem abas
font pango:monospace 0.001
titlebar_border_thickness 0
titlebar_padding 0
## bordas
smart_borders on
hide_edge_borders smart
for_window [app_id=".*"] border pixel 1
default_border pixel 1
default_floating_border pixel 4
## cores
### classe               borda   fundo   texto   indicador  child_border
client.focused           #d65d0e #282828 #d5c4a1 #83a598    #83a598
client.focused_inactive  #282828 #282828 #d5c4a1 #282828    #282828
client.unfocused         #282828 #282828 #d5c4a1 #282828    #282828
client.urgent            #ff0000 #282828 #d5c4a1 #ff0000    #ff0000
client.placeholder       #555555 #555555 #d5c4a1 #555555    #555555
client.background        #000000

# Regras
for_window [app_id="^Picture-in-Picture$"] {
  floating enable
  resize set height 350
  resize set width  600
  border none
  sticky toggle
  move position 680 370
  opacity 0.85
}
for_window [title="^Picture-in-Picture$"] {
  floating enable
  resize set height 350
  resize set width  600
  border none
  sticky toggle
  move position 680 370
  opacity 0.85
}
## Não desliga a tela quando em tela cheia
for_window [class="^.*"] inhibit_idle fullscreen
for_window [app_id="^.*"] inhibit_idle fullscreen
for_window [app_id=".*"] title_window_icon on
for_window [app_id="^menu$"] floating enable, border pixel 4, resize set 400 300, move position center
for_window [app_id="^float$"] floating enable, border pixel 4, resize set 1000 600, move position center
for_window [app_id="^pinentry-qt$"] floating enable, border pixel 4, resize set 600 400, move position center
for_window [app_id="^calculadora"] floating enable, border pixel 4, resize set 200 200, move position center
for_window [app_id="org.qutebrowser.qutebrowser"] focus
for_window [app_id="^Firefox$"] focus
for_window [app_id="^firefox$"] focus
for_window [app_id="^emacs$"] focus
for_window [instance="^emacs$"] focus
for_window [app_id="^nvim$"] focus
for_window [app_id="^foot$"] focus
for_window [app_id="^alacritty$"] focus
for_window [app_id="^mpv$"] focus
for_window [app_id="^Gimp$"] focus
for_window [app_id="^discord$"] focus
for_window [app_id="^irc$"] focus
for_window [instance="^irc$"] focus
for_window [app_id="^TelegramDesktop$"] focus
assign [app_id="org.qutebrowser.qutebrowser"] "1:Browser"
assign [app_id="^Firefox$"] "1:Browser"
assign [app_id="^firefox$"] "1:Browser"
assign [app_id="^emacs$"] "2:Code"
assign [instance="^emacs$"] "2:Code"
assign [app_id="^nvim$"] "2:Code"
assign [app_id="^foot$"] "2:Code"
assign [app_id="^alacritty$"] "2:Code"
assign [app_id="^mpv$"] "3:Fullscreen"
assign [app_id="^Gimp$"] "3:Fullscreen"
assign [app_id="^discord$"] "4:Message"
assign [app_id="^irc$"] "4:Message"
assign [instance="^irc$"] "4:Message"
assign [app_id="^TelegramDesktop$"] "4:Message"

# Teclas
set $mod Mod4
set $mods Mod4+Shift
floating_modifier $mod normal
## sway
bindsym $mod+q kill
bindsym $mod+w floating toggle
bindsym $mod+f fullscreen toggle
bindsym $mod+b bar hidden_state toggle
bindsym $mod+tab exec swayr next-window current-workspace
bindsym $mod+Mod1+period exec swayr next-window current-workspace
bindsym Print exec wayland_print
bindsym $mod+e exec term_open -a nvim nvim
bindsym $mod+o exec menu_pesquisar
bindsym $mods+Return exec term_open
## menu
mode "Menu" {
    bindsym Menu exec pgrep tofi && pkill tofi || tofi-drun --drun-launch=true ; mode "default"
    bindsym o exec orgmenu ~/documentos/favs.md ; mode "default"
    bindsym m exec menu_mont ; mode "default"
    bindsym p exec keepmenu ; mode "default"
    bindsym c exec cliphist list | tofi --padding-left 0 --padding-top 0 | cliphist decode | wl-copy ; mode "default"
    bindsym Shift+c exec term_open -a calculadora bc ; mode "default"
    bindsym Shift+e exec term_open -a float fzf_emojis ; mode "default"
    bindsym f exec firefox ; mode "default"
    bindsym h exec term_open -a float htop ; mode "default"
    bindsym s exec gammastep -O 3000 ; mode "default"
    bindsym Shift+s exec pkill -x gammastep ; mode "default"
    bindsym t exec term_open -a tremc tremc ; mode "default"
    bindsym a exec term_open -a nvim nvim ~/documentos/anotações.md ; mode "default"
    bindsym e exec term_open -a nvim nvim ~/documentos/ ; mode "default"
    bindsym l exec swaylock -c 000000ff --scaling fill ; mode "default"
    bindsym r reload
    bindsym Shift+q exit
    bindsym Ctrl+Shift+q exec powermenu ; mode "default"
    bindsym XF86Launch2 exec powermenu ; mode "default"
    bindsym escape ; mode "default"
}
bindsym Menu mode "Menu"
## resize mode
mode "resize" {
        bindsym h resize shrink width 10 px or 10 ppt
        bindsym j resize grow height 10 px or 10 ppt
        bindsym k resize shrink height 10 px or 10 ppt
        bindsym l resize grow width 10 px or 10 ppt
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"
## musica
bindsym $mod+a exec term_open -a float ncmpcpp
bindsym $mods+a exec term_open -a float pulsemixer
bindsym $mod+space exec playerctl play-pause || mpc toggle
bindsym XF86AudioPlay exec playerctl play-pause || mpc toggle
bindsym $mod+comma exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym $mod+period exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym $mods+comma exec musica ante
bindsym $mods+period exec musica prox
## setas/vimkeys
bindsym $mod+Up focus up
bindsym $mod+Down focus down
bindsym $mod+Left focus left
bindsym $mod+Right focus right
bindsym $mods+Up move up
bindsym $mods+Down move down
bindsym $mods+Left move left
bindsym $mods+Right move right
bindsym $mod+k focus up
bindsym $mod+j focus down
bindsym $mod+h focus left
bindsym $mod+l focus right
bindsym $mods+k move up
bindsym $mods+j move down
bindsym $mods+h move left
bindsym $mods+l move right
## workspaces
set $ws1 "1:Browser"
set $ws2 "2:Code"
set $ws3 "3:Fullscreen"
set $ws4 "4:Message"
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mods+1 move window to workspace number $ws1
bindsym $mods+2 move window to workspace number $ws2
bindsym $mods+3 move window to workspace number $ws3
bindsym $mods+4 move window to workspace number $ws4

# Iniciar
exec swayrd
exec swayidle -w timeout 500 'swaymsg "output * power off"' resume 'swaymsg "output * power on"'
exec wl-paste --watch cliphist store
exec mako
exec alacritty --class irc -e irssi --home ~/.config/irssi
## Musica
exec pgrep -x "playerctld" || playerctld daemon
exec pgrep -x "mpDris2" || mpDris2 --music-dir="$HOME/media/musicas/" >"$XDG_CACHE_HOME/mpdris2.log" 2>&1 &
## aparência
exec xrdb -load $HOME/.config/x11/xresources
## sistema
exec checar_updates

## Barra
bar {
  swaybar_command waybar
  mode hide
  hidden_state hide
  modifier Mod4
}
