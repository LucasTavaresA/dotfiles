    term_open -a fzf fzf_wifi
## fzf_xephyr
Menu;x
    term_open -a fzf fzf_xephyr
## fzf_clip
Menu;c
    term_open -a fzf fzf_clip
## fzf_emoji
Menu;E
    term_open -a fzf fzf_emojis
## fzf_sxhkd
