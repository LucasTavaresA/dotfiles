# Menus
## dmenu_run
Menu;Menu
    dmenu_run
## fzf_sys
Menu;{Escape,XF86Launch2}
    term_open -a fzf fzf_sys
## org_dmenu
Menu;o
    org_dmenu ~/documentos/favoritos.org
## dmenu_mont
Menu;m
    dmenu_mont
## passmenu
Menu;p
    passmenu --type
