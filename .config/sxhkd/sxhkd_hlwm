# Menus
Menu;Menu
  dmenu_run -b -i -l 15 -p '>' -fn 'Iosevka:pixelsize=22'

Menu;o
  orgmenu ~/documentos/favs.md

Menu;m
  menu_mont

Menu;p
  keepassxc

Menu;c
  clipmenu -b -i -l 15 -p '>' -fn 'Iosevka:pixelsize=22'

Menu;E
  term_open -a float fzf_emojis

Print
  xorg_print

# herbstluftwm
Menu;q
  herbstclient quit

Menu;r
  herbstclient reload

# outros
Menu;f
  qutebrowser

Menu;h
  term_open -a float htop

Menu;P
  pkill -x picom || picom

Menu;C
  term_open -a calculadora csharprepl

Menu;l
  slock

# editar
Menu;e
  term_open -a nvim nvim ~/documentos/

Menu;a
  term_open -a nvim nvim ~/documentos/anotações.md
