## dmenu_print
Print
    dmenu_print

# Outros
## qutebrowser
Menu;q
    qutebrowser
## firefox
Menu;f
    firefox
## htop
Menu;h
    term_open -a htop htop
## picom
Menu;P
    pkill -x picom || picom -b --unredir-if-possible --backend xr_glx_hybrid --vsync --use-damage --glx-no-stencil
## sct
Menu;{s,S}
    {sct,sct 2000}
## transmission
Menu;t
    transmission-qt
## calculadora
Menu;C
    term_open -a calculadora python

# arquivos
## abre o emacs
Menu;e
    emacsclient -n -c -a 'term_open nvim'
## anotações
Menu;a
    emacsclient -n -c -a 'term_open nvim' ~/documentos/anotações.org
