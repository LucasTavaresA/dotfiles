{
    "spacing": 10,
    "position": "bottom",
    "ipc": true, // bar on-hold
    "fixed-center": false, // center sway/window

    // Choose the order of the modules
    "modules-left": [
        "wireplumber",
        "custom/music",
        "sway/mode"
    ],
    // "modules-center": [
    //     "sway/window"
    // ],
    "modules-right": [
        "network",
        "disk#1",
        "disk#2",
        "battery",
        "battery#bat2",
        "backlight",
        "clock",
        "tray"
    ],

    // Modules configuration
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "<span>{icon}</span>",
        "format-icons": {
            "urgent": "!",
            "focused": "X",
            "default": ""
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    // "mpd": {
    //     "format": "🎵 {filename:.40} [{songPosition}/{queueLength}]",
    //     "format-disconnected": "🎵 Disconnected",
    //     "format-stopped": "🎵 Stopped",
    //     "unknown-tag": "N/A",
    //     "interval": 2,
    //     "tooltip-format": "MPD (connected)",
    //     "tooltip-format-disconnected": "MPD (disconnected)",
    //     "on-click": "term_open -a ncmpcpp ncmpcpp"
    // },
    "network": {
        "format": "{essid:.10} 🌐",
    },
    "mpris": {
        "format": "{player_icon} {status_icon} {dynamic}",
        "format-paused": "{player_icon} {status_icon} <i>{dynamic}</i>",
        "max-length": 45,
        "player-icons": {
            "chromium": "爵",
            "default": "",
            "firefox": "",
            "kdeconnect": "",
            "mopidy": "",
            "mpv": "",
            "spotify": "阮"
        },
        "status-icons": {
            "paused": "",
            "playing": "契",
            "stopped": "栗"
        }
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "🔵 {volume}%",
        "format-bluetooth-muted": "🔵 🔇",
        "format-muted": "🔇",
        "format-icons": {
            "headphone": "🎧",
            "hands-free": "🔵",
            "headset": "🎧",
            "phone": "📱",
            "portable": "📱",
            "car": "🚗",
            "default": ["🔈", "🔉", "🔊"]
        },
        "on-click": "term_open -a float pulsemixer"
    },
    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-muted": "🔇",
        "format-bluetooth": "🔵 {volume}%",
        "format-bluetooth-muted": "🔵 🔇",
        "format-icons": {
            "headphone": "🎧",
            "hands-free": "🔵",
            "headset": "🎧",
            "phone": "📱",
            "portable": "📱",
            "car": "🚗",
            "default": ["🔈", "🔉", "🔊"]
        },
        "on-click": "term_open -a float pulsemixer",
        "scroll-step": 0.2,
    },
    "disk#1": {
        "format": "{path} {free}",
        "path": "/",
    },
    "disk#2": {
        "format": "{path} {free}",
        "path": "/home",
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["▁", "▃", "▅", "▇"],
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% Charging",
        "format-plugged": "{capacity}% Plugged",
        "format-icons": ["▁", "▃", "▅", "▇"],
    },
    "battery#bat2": {
        "bat": "BAT2",
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% Charging",
        "format-plugged": "{capacity}% Plugged",
        "format-icons": ["▁", "▃", "▅", "▇"],
    },
    "clock": {
        "format": "{:%a %d/%m/%Y - %H:%M}",
    },
    "custom/music": {
        "interval": 2,
        "format": "{icon} {}",
        "format-icons": {
            "default": "🎵"
        },
        "exec": "$HOME/code/shellscripts/shellscripts/musica tocando",
        "on-click": "term_open -a ncmpcpp ncmpcpp"
    },
}
// vim: set ft=jsonc:
