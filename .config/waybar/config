{
    "spacing": 10,
    "position": "bottom",
    "ipc": true, // bar on-hold
    "fixed-center": false, // center sway/window

    // Choose the order of the modules
    "modules-left": [
        "sway/workspaces",
        "sway/mode"
    ],
    "modules-center": [
        "sway/window"
    ],
    "modules-right": [
        "mpd",
        "pulseaudio",
        "disk#1",
        "disk#2",
        "backlight",
        "battery",
        "battery#bat2",
        "clock",
        "tray"
    ],

    // Modules configuration
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "<span>{icon}</span>",
        "format-icons": {
            "urgent": "!",
            "focused": "X",
            "default": ""
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "mpd": {
        "format": "рЯОµ {filename:.40} [{songPosition}/{queueLength}]",
        "format-disconnected": "рЯОµ Disconnected",
        "format-stopped": "рЯОµ Stopped",
        "unknown-tag": "N/A",
        "interval": 2,
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)",
        "on-click": "term_open -a float ncmpcpp"
    },
    "mpris": {
        "format": "{player_icon} {status_icon} {dynamic}",
        "format-paused": "{player_icon} {status_icon} <i>{dynamic}</i>",
        "max-length": 45,
        "player-icons": {
            "chromium": "п™Ю",
            "default": "",
            "firefox": "пЙ©",
            "kdeconnect": "пШЯ",
            "mopidy": "пАБ",
            "mpv": "пҐА",
            "spotify": "пІЖ"
        },
        "status-icons": {
            "paused": "п££",
            "playing": "п§Й",
            "stopped": "пІЪ"
        }
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon}{volume}%пКФ",
        "format-bluetooth-muted": "пЪ© {icon}пКФ",
        "format-muted": "пЪ©",
        "format-icons": {
            "headphone": "пА•",
            "hands-free": "пЦР",
            "headset": "пЦР",
            "phone": "пВХ",
            "portable": "пВХ",
            "car": "пЖє",
            "default": ["рЯФИ", "рЯФЙ", "рЯФК"]
        },
        "on-click": "term_open -a float pulsemixer"
    },
    "disk#1": {
        "format": "{path} {free}",
        "path": "/",
    },
    "disk#2": {
        "format": "{path} {free}",
        "path": "/home",
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% пЧІ",
        "format-plugged": "{capacity}% пЗ¶",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "clock": {
        "format": "{:%a %d/%m/%Y - %H:%M}",
    },
}
