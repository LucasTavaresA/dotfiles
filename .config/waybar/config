{
    "spacing": 10,
    "position": "bottom",
    "ipc": true, // bar on-hold
    "fixed-center": false, // center sway/window

    // Choose the order of the modules
    "modules-left": [
        "sway/workspaces",
        "sway/mode"
    ],
    "modules-center": [
        "sway/window"
    ],
    "modules-right": [
        "mpd",
        "pulseaudio",
        "disk#1",
        "disk#2",
        "backlight",
        "battery",
        "battery#bat2",
        "clock",
        "tray"
    ],

    // Modules configuration
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "<span font_family='Symbols Nerd Font Mono'>{icon}</span>",
        "format-icons": {
            "1:Browser": "яЙй",
            "2:Code": "яДа",
            "3:Fullscreen": "юнМ",
            "4:Message": "яБ╡",
            "urgent": "яБк",
            "focused": "яЖТ",
            "default": "яДС"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/window": {
        "format": "{title}",
        "rewrite": {
            "(.*) тАФ Mozilla Firefox": "<span font_family='Symbols Nerd Font Mono'>якЮ</span> $1",
            "(.*) - qutebrowser": "<span font_family='Symbols Nerd Font Mono'>якЮ</span> $1",
            "(.*) - NVIM": "<span font_family='Symbols Nerd Font Mono'>юШл</span> $1",
            "^(~.*)": "$1<span font='14' rise='-2pt'>></span>",
        }
    },
    "mpd": {
        "format": "ЁЯО╡ {filename:.40} [{songPosition}/{queueLength}]",
        "format-disconnected": "ЁЯО╡ Disconnected",
        "format-stopped": "ЁЯО╡ Stopped",
        "unknown-tag": "N/A",
        "interval": 2,
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)",
        "on-click": "alacritty -e ncmpcpp"
    },
    "mpris": {
        "format": "{player_icon} {status_icon} {dynamic}",
        "format-paused": "{player_icon} {status_icon} <i>{dynamic}</i>",
        "max-length": 45,
        "player-icons": {
            "chromium": "якЮ",
            "default": "",
            "firefox": "яЙй",
            "kdeconnect": "яШЯ",
            "mopidy": "яАБ",
            "mpv": "явА",
            "spotify": "язЖ"
        },
        "status-icons": {
            "paused": "ягг",
            "playing": "ядЙ",
            "stopped": "язЪ"
        }
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon}{volume}%яКФ",
        "format-bluetooth-muted": "яЪй {icon}яКФ",
        "format-muted": "яЪй",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["ЁЯФИ", "ЁЯФЙ", "ЁЯФК"]
        },
        "on-click": "alacritty -e pulsemixer"
    },
    "disk#1": {
        "format": "{path} {free}",
        "path": "/",
    },
    "disk#2": {
        "format": "{path} {free}",
        "path": "/home",
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% яЧз",
        "format-plugged": "{capacity}% яЗж",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "clock": {
        "format": "{:%a %d/%m/%Y - %H:%M}",
    },
}
// vim: set ft=jsonc:
