# List of valid properties:
#
# align
# color
# command
# full_text
# instance
# interval
# label
# min_width
# name
# separator
# separator_block_width
# short_text
# signal
# urgent

# Global properties
#
# The top properties below are applied to every block, but can be overridden.
# Each block command defaults to the script name to avoid boilerplate.
# Change $SCRIPT_DIR to the location of your scripts!
command=$XDG_DATA_HOME/i3blocks/$BLOCK_NAME/$BLOCK_NAME
separator_block_width=15
separator=" "
markup=none

[musica]
command=echo $(musica tocando)
interval=5
signal=18

[volume]
command=echo $(volume)
interval=once
signal=22

[separador]
full_text="                                     "

[data]
command=date '+%a %d/%m/%Y - %H:%M'
interval=60
