[init]
	defaultBranch = main

[core]
	editor = nvim
	pager = delta

[commit]
	gpgsign = true

[github]
	user = LucasTavaresA

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	dark = true      # or light = true, or omit for auto-detection
	tabs = 2

[diff]
	colorMoved = plain
	algorithm = histogram

[merge]
	conflictstyle = zdiff3

[branch]
	sort = -committerdate

[tag]
	sort = version:refname

[push]
	autoSetupRemote = true
	followTags = true
