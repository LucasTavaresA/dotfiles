" unbind in commandline
unbind --mode=ex <C-c>
unbind --mode=ex <C-w>

unbind M
unbind m
unbind u
unbind .
unbind q
unbind H
unbind L
unbind O

" Hint only titles and menu options on yt
bindurl youtube.com/feed f hint -Jc .yt-simple-endpoint:not(.ytd-thumbnail)
bindurl youtube.com/feed F hint -Jc .yt-simple-endpoint:not(.ytd-thumbnail)
bindurl youtube.com/channel f hint -Jc .yt-simple-endpoint:not(.ytd-thumbnail)
bindurl youtube.com/channel F hint -Jc .yt-simple-endpoint:not(.ytd-thumbnail)

" TODO: bindings
bind O fillcmdline winopen
bind j scrollline 4
bind k scrollline -4
bind <C-a> back
bind <C-d> forward
bind A fillcmdline back
bind D fillcmdline forward
bind ZZ composite sanitise tridactyllocal tridactylsync; qall

" use native C-f
unbind <C-f>
" But also support Tridactyl search too.
bind / fillcmdline find
bind ? fillcmdline find -?
bind n findnext 1
bind N findnext -1
set incsearch true

" vi:ft=vim
