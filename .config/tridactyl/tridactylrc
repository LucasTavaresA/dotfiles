colorscheme shydactyl

""" Misc
" Make Tridactyl work on more sites at the expense of some security
" removed due to firefox request
" set csp clobber
fixamo_quiet

set allowautofocus false

set externalclipboardcmd xclip
set yankto both

set smoothscroll false

" Sane hinting mode
set hintfiltermode vimperator-reflow
set hintchars asdfghjkl

" remove native search engines
setnull searchurls.google
setnull searchurls.googlelucky
setnull searchurls.scholar
setnull searchurls.googleuk
setnull searchurls.bing
setnull searchurls.duckduckgo
setnull searchurls.yahoo
setnull searchurls.twitter
setnull searchurls.wikipedia
setnull searchurls.youtube
setnull searchurls.amazon
setnull searchurls.amazonuk
setnull searchurls.startpage
setnull searchurls.github
setnull searchurls.searx
setnull searchurls.cnrtl
setnull searchurls.osm
setnull searchurls.mdn
setnull searchurls.gentoo_wiki
setnull searchurls.qwant

" search engines
set searchengine s
set jsurls.s    query => query == "" ? "https://baresearch.org/" : "https://baresearch.org/search?q=" + query
set jsurls.g    query => query == "" ? "https://www.google.com" : "https://www.google.com/search?q=" + query
set jsurls.yt   query => query == "" ? "https://www.youtube.com/feed/subscriptions" : "https://www.youtube.com/search?q=" + query
set jsurls.ytb  query => query == "" ? "https://www.youtube.com/feed/library" : "https://www.youtube.com/search?q=" + query
set jsurls.al   query => query == "" ? "https://anilist.co/" : "https://anilist.co/"
set jsurls.alm  query => query == "" ? "https://anilist.co/user/Lucastavares/animelist" : "https://anilist.co/search/manga?search=" + query + "&sort=SEARCH_MATCH"
set jsurls.ala  query => query == "" ? "https://anilist.co/user/Lucastavares/mangalist" : "https://anilist.co/search/anime?search=" + query + "&sort=SEARCH_MATCH"
set jsurls.aur  query => query == "" ? "https://aur.archlinux.org" : "https://aur.archlinux.org/packages?O=0&SeB=nd&K=" + query + "&outdated=&SB=p&SO=d&PP=50&submit=Go"
set jsurls.aw   query => query == "" ? "https://wiki.archlinux.org" : "https://wiki.archlinux.org/index.php?search=" + query
set jsurls.br   query => query == "" ? "https://brainly.com.br" : "https://brainly.com.br/app/ask?q=" + query
set jsurls.fb   query => query == "" ? "https://www.facebook.com/""https://www.facebook.com/"
set jsurls.fp   query => query == "" ? "https://www.freshports.org" : "https://www.freshports.org/search.php?query=" + query + "&search=go&num=10&stype=name&method=match&deleted=excludedeleted&start=1&casesensitivity=caseinsensitive"
set jsurls.gf   query => query == "" ? "https://greasyfork.org" : "https://greasyfork.org/en/scripts?q=" + query
set jsurls.gh   query => query == "" ? "https://github.com" : "https://github.com/search?q=" + query
set jsurls.gl   query => query == "" ? "https://gitlab.com" : "https://gitlab.com/search?search=" + query
set jsurls.gm   query => query == "" ? "https://www.google.com.br/maps" : "https://www.google.com.br/maps/search/" + query
set jsurls.gpt  query => query == "" ? "https://chat.openai.com/chat" : "https://chat.openai.com/chat"
set jsurls.gt   query => query == "" ? "https://translate.google.com" : "https://translate.google.com/?sl=auto&tl=en&text=" + query
set jsurls.imdb query => query == "" ? "https://www.imdb.com" : "https://www.imdb.com/find?q=" + query + "&ref_=nv_sr_sm"
set jsurls.md   query => query == "" ? "https://mangadex.org/titles/feed" : "https://mangadex.org/titles?page=1&q=" + query + "&order=relevance.desc"
set jsurls.th   query => query == "" ? "https://tenhou.net/3/" : "https://tenhou.net/3/"
set jsurls.od   query => query == "" ? "https://odysee.com" : "https://odysee.com/search?q=" + query
set jsurls.r    query => query == "" ? "https://www.reddit.com" : "https://www.reddit.com/search/?q=" + query
set jsurls.sc   query => query == "" ? "https://soundcloud.com/you/likes" : "https://soundcloud.com/search?q=" + query
set jsurls.se   query => query == "" ? "https://stackexchange.com" : "https://stackexchange.com/search?q=" + query
set jsurls.sf   query => query == "" ? "https://sourceforge.net" : "https://sourceforge.net/directory/?q=" + query
set jsurls.sync query => query == "" ? "http://127.0.0.1:8384/" : "http://127.0.0.1:8384/"
set jsurls.tc   query => query == "" ? "https://twitch.com" : "https://www.twitch.tv/search?term=" + query
set jsurls.tw   query => query == "" ? "https://twitter.com" : "https://twitter.com/search?q=" + query
set jsurls.tg   query => query == "" ? "https://trends.google.com.br" : "https://trends.google.com.br/trends/explore?q=" + query
set jsurls.ud   query => query == "" ? "https://www.urbandictionary.com" : "https://www.urbandictionary.com/define.php?term=" + query
set jsurls.vn   query => query == "" ? "https://vndb.org" : "https://vndb.org/v?sq=" + query
set jsurls.vt   query => query == "" ? "https://www.virustotal.com/gui/" : "https://www.virustotal.com/gui/"
set jsurls.wa   query => query == "" ? "https://web.whatsapp.com/" : "https://web.whatsapp.com/"
set jsurls.wm   query => query == "" ? "https://web.archive.org" : "https://web.archive.org/web/*/" + query

" unbind in commandline
unbind --mode=ex <C-c>
unbind --mode=ex <C-w>

unbind M
unbind m
unbind u
unbind d
unbind .
unbind q
unbind H
unbind L
unbind O
unbind p
unbind P

bind O fillcmdline winopen
bind j scrollline 4
bind k scrollline -4
bind <C-j> scrollpage 1
bind <C-k> scrollpage -1
bind u undo window
bind <C-a> back
bind <C-d> forward
bind A fillcmdline back
bind D fillcmdline forward
bind ZZ composite sanitise tridactyllocal tridactylsync; qall
bind qvw hint -W js -p tri.excmds.shellescape(JS_ARG).then(url => tri.excmds.exclaim_quiet('mpv --ytdl-format=\'worstvideo*[height=720]+worstaudio/worst[height=720]\' --cache=yes --demuxer-max-bytes=2048Kib --wayland-app-id=Picture-in-Picture ' + url))
bind qsw hint -W js -p tri.excmds.shellescape(JS_ARG).then(url => tri.excmds.exclaim_quiet('streamlink -a \'--wayland-app-id=Picture-in-Picture\' ' + url))
bind qvd hint -W js -p tri.excmds.shellescape(JS_ARG).then(url => tri.excmds.exclaim_quiet('term_open -a float yt-dlp -P ~/Downloads --write-subs -f \'worstvideo*[height=720]+worstaudio/worst[height=720]\' ' + url))
bind qid hint -A
bind qad hint -W js -p tri.excmds.shellescape(JS_ARG).then(url => tri.excmds.exclaim_quiet('term_open -a float yt-dlp -x ' + url))
bind qq hint -W js -p tri.excmds.shellescape(JS_ARG).then(url => tri.excmds.exclaim_quiet('qutebrowser ' + url))
bind cl hint -y
bind cc hint -p
bind z hint -W js -p tri.excmds.shellescape(JS_ARG).then(url => tri.excmds.exclaim_quiet('echo ' + url + ' >> ~/copied.txt'))

" use native C-f
unbind <C-f>
" But also support Tridactyl search too.
bind / fillcmdline find
bind ? fillcmdline find -?
bind n findnext 1
bind N findnext -? 1
set incsearch true

" vi:ft=vim
