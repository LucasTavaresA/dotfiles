#!/usr/bin/env sh
# shellcheck disable=SC2016
UID="$(id -u)"
HOSTNAME="$(uname -n)"
set -ex

# executar apenas como root
[ "$UID" != 0 ] && echo "root necessário!" && exit 1
[ "$(pwd)" = /home/lucas ] && echo "Deve ser executado em /home/lucas" && exit 1
[ ! -d /home/lucas/etc ] && echo "Diretório /home/lucas/etc não encontrado!" && exit 1
[ ! -d /home/lucas/etc/.dotfiles ] && echo "Clone e ajuste os dotfiles" && exit 1

xbps-install -Su
xbps-install -S "$(cat etc/pkgs/"$HOSTNAME".txt)"
[ "$(xpkg | wc -l)" -lt "$(cat etc/pkgs/"$HOSTNAME".txt)" ] &&
    echo "Faltam pacotes" && exit 1

microcode() {
    echo "microcode Intel/Amd [i/a]? "
    read -r marca
    case "$marca" in
        "i") xbps-install -S intel-ucode && xbps-reconfigure --force ;;
        "a") xbps-install -S linux-firmware-amd ;;
        *) microcode ;;
    esac
}
microcode

sed -i 's/^#en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/g' /etc/default/libc-locales
xbps-reconfigure -f glibc-locales
cp -f etc/locale.conf /etc/locale.conf

chsh -s /bin/fish
chsh -s /bin/sh lucas
(
    cd code/c/dash/
    ./autogen.sh
    ./configure --bindir=/bin --mandir=/usr/share/man
    make
    make install
)

cp etc/voidlinux/ignore-sudo.conf /etc/xbps.d/
xbps-remove -R sudo
cp etc/doas.conf /etc/

ln -s /etc/sv/socklog-unix /var/service/
ln -s /etc/sv/nanoklogd /var/service/

cp etc/voidlinux/rc.local /etc/rc.local

ln -s /etc/sv/acpid /var/service/

[ "$(wc -l /etc/hosts)" -lt 15 ] && cat etc/hosts >>/etc/hosts

ln -s /etc/sv/dbus /var/service/

ln -s /etc/sv/seatd /var/service/
usermod -aG _seatd lucas

gpu() {
    echo "gpu Intel/Amd-Ati [i/a]? "
    read -r marca
    case "$marca" in
        "i") xbps-install -S linux-firmware-intel mesa-dri mesa-dri-32bit vulkan-loader vulkan-loader-32bit mesa-vulkan-intel mesa-vulkan-intel-32bit intel-video-accel libva-intel-driver libva-intel-driver-32bit ;;
        "a") xbps-install -S linux-firmware-amd mesa-dri mesa-dri-32bit vulkan-loader vulkan-loader-32bit mesa-vulkan-radeon-32bit amdvlk amdvlk-32bit mesa-vdpau mesa-vdpau-32bit mesa-vaapi mesa-vaapi-32bit ;;
        *) gpu ;;
    esac
}
gpu

mkdir -p /etc/alsa/conf.d
ln -s /usr/share/alsa/alsa.conf.d/50-pipewire.conf /etc/alsa/conf.d
ln -s /usr/share/alsa/alsa.conf.d/99-pipewire-default.conf /etc/alsa/conf.d

(
    cd code/c/fastfetch
    build.sh
)

cargo install handlr-regex tree-sitter-cli

git clone https://github.com/horriblename/lf
(
    cd lf
    env CGO_ENABLED=0 go install -ldflags="-s -w" github.com/horriblename/lf@latest
)
rm -r lf

go install github.com/mrtazz/checkmake/cmd/checkmake@latest
go install github.com/nametake/golangci-lint-langserver@latest

npm i -g cssmodules-language-server @tailwindcss/language-server typescript \
    typescript-language-server vscode-langservers-extracted \
    fixjson bash-language-server vscode-css-languageserver-bin \
    neovim write-good
npm i -g --save-exact prettier

pipx install keepmenu scdl spotdl jedi-language-server

git clone https://github.com/TheGreatMcPain/gruvbox-material-gtk
(
    cp -r gruvbox-material-gtk/icons/* /usr/share/icons/
    cp -r gruvbox-material-gtk/themes/* /usr/share/themes/
)
rm -r gruvbox-material-gtk

wget https://github.com/sainnhe/capitaine-cursors/releases/download/r5/Linux.zip
mkdir cursors
unzip Linux.zip -d cursors
mv cursors/Capitaine\ Cursors\ \(Gruvbox\)/ /usr/share/icons/
mkdir -p /home/lucas/.local/share/icons/default/
cat etc/index.theme >/home/lucas/.local/share/icons/default/index.theme

cat etc/pam_gnupg >>/etc/pam.d/login

mkdir -p /home/lucas/.local/share/applications/
cp etc/transmission-remote.desktop .local/share/applications/
cp etc/term_open.desktop .local/share/applications/
