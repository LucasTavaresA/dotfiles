#!/bin/sh
# Default rc.local for void; add your custom commands here.
#
# This is run by runit in stage 2 before the services are executed
# (see /etc/runit/2).

# start on max brightness
if [ -e /sys/class/backlight/amdgpu_bl0/brightness ] && [ -e /sys/class/backlight/amdgpu_bl0/max_brightness ]; then
	cat /sys/class/backlight/amdgpu_bl0/max_brightness >/sys/class/backlight/amdgpu_bl0/brightness
fi
